# szbolent-portal — 本地开发环境变量
# 复制为 .env.local 后修改（勿提交密钥）
# 腾讯云 P0–P2 清单：docs/TENCENT_CLOUD_COMMERCE.md

# 门户公网地址（SEO / OG）
VITE_SITE_URL=http://localhost:3000

# Looma 商业/API 真源（生产：https://api.szbolent.cn）
# 本地留空则走 vite proxy /v1 → :5200
VITE_LOOMA_API_BASE=

# Legacy bolent Sanic（P0-15 后逐步弃用，改 looma /v1/poetry）
VITE_API_BASE=http://127.0.0.1:8001

# WordPress REST API（Poetry-modown headless，本地 Docker 默认 :8800）
# 开发时 vite 已代理 /wp-json → localhost:8000，可按实际改 vite.config.ts
VITE_BLOG_API_BASE=/wp-json/wp/v2

# Tatha 诗词 RAG — 已废弃（原 Tatha RAG 已完全融入 Looma backend/src/rag/）
# 保留仅作历史参考，生产环境不应启用
VITE_TATHA_URL=http://127.0.0.1:8010
VITE_TATHA_POETRY_ENABLED=false
