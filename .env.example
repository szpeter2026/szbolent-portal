# szbolent-portal — 环境变量模板
# 复制为 .env.local 后修改（勿提交密钥）

# 门户公网地址（SEO / OG 用）
VITE_SITE_URL=http://localhost:3000

# Looma 商业/API 真源
# 本地留空 → vite proxy /v1 → :5200
# 生产填：http://api.genz.ltd
VITE_LOOMA_API_BASE=

# WordPress REST API（Poetry-modown headless）
# 开发时 vite 已代理 /wp-json → :8800
VITE_BLOG_API_BASE=/wp-json/wp/v2
